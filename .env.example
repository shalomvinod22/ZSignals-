# Copy this file to .env (no extension change), fill in your key

# Choose: groq or ollama
LLM_PROVIDER=groq

# Groq settings — free key at console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama settings — only used if LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# Apify — fallback scraper when Reddit/G2 native methods get blocked
# Get free token at console.apify.com -> Settings -> Integrations
APIFY_API_TOKEN=apify_api_your_token_here

# Optional: if user wants PRAW instead of public JSON (advanced)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=zintlr-pulse/1.0